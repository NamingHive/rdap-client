{
  "name": "naminghive/rdap-client",
  "description": "A PHP client to query RDAP (formerly WHOIS) services",
  "minimum-stability": "stable",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.0"
  },
  "authors": [
    {
      "name": "Rayhan Sardar",
      "email": "rayhan@kha.icu"
    }
  ],
  "autoload": {
    "psr-4": {
      "NamingHive\\RDAP\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NamingHive\\RDAP\\Tests\\": "tests"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0"
  }
}